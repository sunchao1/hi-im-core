# 基础镜像（Docker Hub 超时时改为国内镜像前缀）
# 用法: cp .env.example .env
#
# 官方（默认，需能访问 registry-1.docker.io）:
# HIIM_BASE_IMAGE=ubuntu:22.04
#
# DaoCloud 镜像（国内常用）:
HIIM_BASE_IMAGE=docker.m.daocloud.io/library/ubuntu:22.04

# 宿主机端口（映射到容器内 28888/28889/8080）
# 本机 8080 已被占用时，保持默认 18080 即可；若要占用 8080 可改为:
# HIIM_HEALTH_HOST_PORT=8080
HIIM_FORWARD_HOST_PORT=28888
HIIM_BACKEND_HOST_PORT=28889
HIIM_HEALTH_HOST_PORT=18080

# 其他可选:
# HIIM_BASE_IMAGE=registry.cn-hangzhou.aliyuncs.com/library/ubuntu:22.04
